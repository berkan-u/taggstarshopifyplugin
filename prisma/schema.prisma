generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Configuration {
  id               Int      @id @default(autoincrement())
  shop             String   @unique
  accountNumber    String?
  siteKey          String?
  region           String?  @default("emea")
  authEnabled      Boolean  @default(false)
  accessKey        String?
  secretKey        String?
  pixelSecret      String?
  enableCategory   Boolean  @default(false)
  enablePDP        Boolean  @default(false)
  enableBasket     Boolean  @default(false)
  enableConversion Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model DiagnosticLog {
  id               Int      @id @default(autoincrement())
  shop             String
  orderId          String   @unique
  requestPayload   String
  responseBody     String
  status           Int
  createdAt        DateTime @default(now())
}
